{
  "extends": "@some-project/ts-config/tsconfig.base.node.json",
  "compilerOptions": {
    "types": ["bun-types"],
    "baseUrl": ".",
    "paths": {
      "@db": ["src/db/index.ts"],
      "@db/*": ["src/db/*"],
      "@movies": ["src/movies/index.ts"],
      "@movies/*": ["src/movies/*"],
      "@api-sources": ["src/api-sources/index.ts"],
      "@api-sources/*": ["src/api-sources/*"],
      "@scan-folders": ["src/scan-folders/index.ts"],
      "@scan-folders/*": ["src/scan-folders/*"]
    }
  },
  "include": ["src/**/*", "drizzle.config.ts"]
}
